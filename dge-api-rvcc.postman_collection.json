    {
      "name": "Pedidos RVCC",
      "item": [
        {
          "name": "Criar pedido RVCC",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_entidade\": {{idEntidade}},\n  \"tipo_documento\": \"BI\",\n  \"numero_documento\": \"{{numeroDocumentoTeste}}\",\n  \"data_emissao\": \"2020-01-15\",\n  \"data_validade\": \"2030-01-15\",\n  \"nome_completo\": \"Candidato Teste RVCC\",\n  \"data_nascimento\": \"1988-05-20\",\n  \"nif\": \"199000001\",\n  \"genero\": \"M\",\n  \"nacionalidade\": \"Cabo-verdiana\",\n  \"ilha\": \"Santiago\",\n  \"concelho\": \"Praia\",\n  \"morada\": \"Palmarejo, Praia\",\n  \"endereco_atual\": \"Palmarejo, Praia\",\n  \"email\": \"candidato.teste@example.com\",\n  \"telemovel\": \"9912345\",\n  \"situacao_emprego\": \"Empregado\",\n  \"empregado\": \"SIM\",\n  \"entidade_empregadora\": \"Empresa Teste, Lda\",\n  \"profissao\": \"Tecnico de Informatica\",\n  \"habilitacao_literaria\": \"12 ano\",\n  \"disponibilidade_horario\": \"Pos-laboral\",\n  \"idade\": 37,\n  \"id_pessoa\": 10001\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pedido/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pedido",
                "create"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var sufixo = Date.now().toString().slice(-8);",
                  "pm.variables.set('numeroDocumentoTeste', 'TESTE-RVCC-' + sufixo);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.idProcesso) {",
                  "  pm.collectionVariables.set('idProcesso', json.idProcesso);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
